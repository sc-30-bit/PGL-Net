{
    "net": "pglnet_t",
    "crop": true,
    "crop_size": 256,
    "bs": 64,
    "lr": 0.0004,
    "eta_min": 4e-8,
    "trainset": "rrshid_train",
    "testset": "rrshid_test",
    "steps": 120000,
    "eval_step": 150,
    "optimizer": "adamw",
    "weight_decay": 0.0,
    "scheduler_type": "cosrestart",
    "restart_periods": "120000",
    "restart_weights": "1",
    "amp": true,
    "loss_type": "l1_fft",
    "fft_loss_weight": 0.1,
    "exp_num": 1
}